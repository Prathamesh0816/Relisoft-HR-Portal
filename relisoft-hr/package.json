{
  "name": "relisoft-hr",
  "version": "1.0.0",
  "description": "ReliSoft HR - Complete HR Management System",
  "scripts": {
    "server": "dotnet run --no-build --project server/RelisoftHR.csproj --launch-profile http",
    "client": "npm --prefix client run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && npm --prefix client install",
    "build": "npm --prefix client run build"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "concurrently": "^8.2.2"
  }
}
